#include <iostream>
using namespace std;

int main(){
    int a[10],n,key,i;

    cout<<"Enter size: ";
    cin>>n;

    cout<<"Enter elements: ";
    for(i=0;i<n;i++)
        cin>>a[i];

    cout<<"Enter key: ";
    cin>>key;

    for(i=0;i<n;i++){
        if(a[i]==key){
            cout<<"Element found at position "<<i+1;
            return 0;
        }
    }

    cout<<"Element not found";
    return 0;
}
