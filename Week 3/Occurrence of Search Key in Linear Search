#include <iostream>
using namespace std;

int main(){
    int a[10],n,key,i,count=0;

    cout<<"Enter size: ";
    cin>>n;

    cout<<"Enter elements: ";
    for(i=0;i<n;i++)
        cin>>a[i];

    cout<<"Enter key: ";
    cin>>key;

    for(i=0;i<n;i++){
        if(a[i]==key)
            count++;
    }

    cout<<"Occurrences = "<<count;
    return 0;
}
