#include <iostream>
using namespace std;

// Define a class
class Student
{
public:
    int id;
    string name;

    void display()
    {
        cout << "Student ID: " << id << endl;
        cout << "Student Name: " << name << endl;
    }
};

int main()
{
    // Create objects
    Student s1;
    Student s2;

    // Assign values
    s1.id = 101;
    s1.name = "Ravi";

    s2.id = 102;
    s2.name = "Priya";

    // Call member function
    s1.display();
    s2.display();

    return 0;
}
