#include <iostream>
using namespace std;

int main(){
    int a[2][2],i,j;

    cout<<"Enter elements:\n";
    for(i=0;i<2;i++)
        for(j=0;j<2;j++)
            cin>>a[i][j];

    cout<<"Matrix:\n";
    for(i=0;i<2;i++){
        for(j=0;j<2;j++)
            cout<<a[i][j]<<" ";
        cout<<endl;
    }

    return 0;
}
